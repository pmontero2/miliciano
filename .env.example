# Miliciano Environment Configuration Template
# Copy this file to .env and fill in your values
# Never commit .env to version control

# =============================================================================
# Python & Runtime
# =============================================================================

# Python interpreter (optional - auto-detected if not set)
#MILICIANO_PYTHON=/usr/bin/python3

# Debug mode - enables verbose logging
#MILICIANO_DEBUG=1

# =============================================================================
# OpenClaw Installation (optional)
# =============================================================================

# Custom OpenClaw installation command
# Used during `miliciano setup --auto`
#MILICIANO_OPENCLAW_INSTALL_CMD="npm install -g openclaw"

# Custom OpenClaw installation URL
# WARNING: Only use trusted sources (https://install.openclaw.io)
#MILICIANO_OPENCLAW_INSTALL_URL=https://install.openclaw.io/install.sh

# =============================================================================
# API Keys (Required for Remote Providers)
# =============================================================================

# OpenAI API Key (for openai-codex provider)
# Get from: https://platform.openai.com/api-keys
#OPENAI_API_KEY=sk-...

# Anthropic API Key (for anthropic provider)
# Get from: https://console.anthropic.com/
#ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter API Key (for openrouter provider)
# Get from: https://openrouter.ai/keys
#OPENROUTER_API_KEY=sk-or-v1-...

# Groq API Key (for groq provider)
# Get from: https://console.groq.com/keys
#GROQ_API_KEY=gsk_...

# Google API Key (for google provider)
#GOOGLE_API_KEY=...

# Mistral API Key (for mistral provider)
#MISTRAL_API_KEY=...

# NVIDIA API Key (for nvidia provider)
# Get from: https://build.nvidia.com/
#NVIDIA_API_KEY=nvapi-...

# =============================================================================
# Policy & Security
# =============================================================================

# Nemoclaw policy enforcement mode
# Options: enforce (default), audit, disabled
# - enforce: Block dangerous operations
# - audit: Log violations but allow execution
# - disabled: No policy checks
NEMOCLAW_POLICY_MODE=enforce

# Path to custom policy configuration
#NEMOCLAW_POLICY_FILE=~/.config/miliciano/policy.yaml

# =============================================================================
# Obsidian Knowledge Graph (optional)
# =============================================================================

# Path to Obsidian vault
# Default: ~/Documents/Obsidian Vault
#OBSIDIAN_VAULT_PATH=~/Documents/Obsidian Vault

# Port for Obsidian graph HTTP server
# Default: 8765
#MILICIANO_OBSIDIAN_PORT=8765

# Host for Obsidian graph server
# Default: 127.0.0.1 (localhost only)
#MILICIANO_OBSIDIAN_HOST=127.0.0.1

# =============================================================================
# Model Configuration
# =============================================================================

# Default Hermes provider
# Options: openai-codex, anthropic, openrouter, groq, custom
#MILICIANO_HERMES_PROVIDER=openai-codex

# Default Hermes model
#MILICIANO_HERMES_MODEL=gpt-4

# Default OpenClaw model (provider/model format)
#MILICIANO_OPENCLAW_MODEL=openai-codex/gpt-4

# Preferred Ollama model for local inference
#MILICIANO_OLLAMA_MODEL=qwen2.5:3b

# =============================================================================
# Logging & Monitoring
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO (DEBUG if MILICIANO_DEBUG=1)
#MILICIANO_LOG_LEVEL=INFO

# Log directory
# Default: ~/.config/miliciano/logs
#MILICIANO_LOG_DIR=~/.config/miliciano/logs

# =============================================================================
# Advanced Settings
# =============================================================================

# Hermes profile directory
# Default: ~/.hermes/profiles/miliciano
#MILICIANO_HERMES_HOME=~/.hermes/profiles/miliciano

# Configuration directory
# Default: ~/.config/miliciano
#MILICIANO_CONFIG_DIR=~/.config/miliciano

# Maximum prompt length (characters)
# Default: 50000
#MILICIANO_MAX_PROMPT_LENGTH=50000

# Policy check timeout (seconds)
# Default: 10
#MILICIANO_POLICY_TIMEOUT=10

# OpenClaw agent timeout (seconds)
# Default: 300 (5 minutes)
#MILICIANO_AGENT_TIMEOUT=300

# =============================================================================
# CI/CD & Testing
# =============================================================================

# Disable interactive prompts (for automated testing)
#MILICIANO_NON_INTERACTIVE=1

# Skip setup validation
#MILICIANO_SKIP_VALIDATION=1

# Mock external services (for testing)
#MILICIANO_MOCK_MODE=1

# =============================================================================
# Example Configurations
# =============================================================================

# Example 1: OpenAI with Nemoclaw enforcement
# OPENAI_API_KEY=sk-...
# NEMOCLAW_POLICY_MODE=enforce
# MILICIANO_DEBUG=0

# Example 2: Local-only with Ollama
# NEMOCLAW_POLICY_MODE=audit
# MILICIANO_OLLAMA_MODEL=llama2:7b
# MILICIANO_DEBUG=1

# Example 3: Multi-provider with fallback
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...
# NEMOCLAW_POLICY_MODE=enforce

# =============================================================================
# Security Best Practices
# =============================================================================

# 1. Never commit .env to version control
# 2. Use environment-specific .env files (.env.development, .env.production)
# 3. Rotate API keys regularly
# 4. Use minimal API key scopes/permissions
# 5. Enable Nemoclaw policy enforcement in production
# 6. Keep MILICIANO_DEBUG=0 in production
# 7. Monitor logs for security events
# 8. Use HTTPS for all API endpoints

# =============================================================================
# Troubleshooting
# =============================================================================

# Enable debug logging:
# MILICIANO_DEBUG=1

# Check configuration:
# miliciano status

# View logs:
# cat ~/.config/miliciano/logs/miliciano.log | tail -50

# Check policy status:
# grep "policy" ~/.config/miliciano/logs/miliciano.log

# Test health check:
# curl http://127.0.0.1:8765/health

# =============================================================================
# Getting Help
# =============================================================================

# Documentation: See docs/ directory
# Issues: https://github.com/milytics/miliciano/issues
# Security: security@milytics.com
