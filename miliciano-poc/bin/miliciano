#!/usr/bin/env python3
import importlib
import sys


def _load(module_name, func_name):
    module = importlib.import_module(module_name)
    return getattr(module, func_name)


COMMANDS = {
    "status": ["miliciano_status", "cmd_status"],
    "model": ["miliciano_controls", "cmd_model"],
    "route": ["miliciano_controls", "cmd_route"],
    "auth": ["miliciano_controls", "cmd_auth"],
    "provider": ["miliciano_controls", "cmd_provider"],
    "permission": ["miliciano_controls", "cmd_permission"],
    "tools": ["miliciano_controls", "cmd_tools"],
    "obsidian": ["miliciano_obsidian", "cmd_obsidian"],
    "setup": ["miliciano_setup", "cmd_setup"],
    "bootstrap": ["miliciano_setup", "cmd_bootstrap"],
    "repair": ["miliciano_setup", "cmd_repair"],
    "doctor": ["miliciano_status", "cmd_doctor"],
    "think": ["miliciano_exec", "cmd_think"],
    "exec": ["miliciano_exec", "cmd_exec"],
    "mission": ["miliciano_exec", "cmd_mission"],
    "shell": ["miliciano_exec", "cmd_shell"],
}

PROMPT_REQUIRED = {
    "think": "Falta prompt para think",
    "exec": "Falta prompt para exec",
    "mission": "Falta objetivo para mission",
}

NO_ARGS = {"repair", "doctor", "shell"}


def usage():
    _load("miliciano_ui", "usage")()


def main():
    if len(sys.argv) < 2:
        _load("miliciano_exec", "cmd_shell")()
        return

    sub = sys.argv[1]
    args = sys.argv[2:]
    arg = " ".join(args).strip()

    if sub in {"-h", "--help", "help"}:
        usage()
        return

    if sub in PROMPT_REQUIRED and not arg:
        print(PROMPT_REQUIRED[sub], file=sys.stderr)
        sys.exit(1)

    target = COMMANDS.get(sub)
    if not target:
        print(f"Subcomando desconocido: {sub}", file=sys.stderr)
        usage()
        sys.exit(1)

    module_name, func_name = target
    command = _load(module_name, func_name)
    if sub in NO_ARGS:
        command()
        return
    command(arg if sub in PROMPT_REQUIRED else args)


if __name__ == "__main__":
    main()
